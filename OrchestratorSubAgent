# Add persistent memory (swap MemorySaver for SqliteSaver for real persistence)
memory = MemorySaver()
app = graph.compile(
    checkpointer=memory,
    interrupt_before=["writer"]   # pause here for human review
)
config = {"configurable": {"thread_id": "session-001"}}

# Run until the interrupt
result = app.invoke({"task": "..."}, config=config)

# Human reviews the analysis before the writer runs
print("Analysis so far:", result["analysis_output"])
approval = input("Approve? (y/n): ")

if approval == "y":
    # Resume the same thread — state is preserved
    final = app.invoke(None, config=config)
    print("HITL: " + final["final_report"])